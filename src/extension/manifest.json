{
  "manifest_version": 3,
  "name": "AID Extension",
  "version": "1.0",
  "description": "AI Information Detection",
  "permissions": [
    "storage",
    "contextMenus",
    "notifications"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "AID Extension",
    "default_icon": "icon.png"
  },
  "icons": {
    "48": "icon.png",
    "96": "icon.png"
  },
  "background": {
    "scripts": ["background.js"]
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "aid-dev@extension.local"
    }
  }
}